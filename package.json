{
  "name": "ai-tools-studio",
  "version": "2.0.0",
  "description": "AI 工具台桌面版 — 一站式 AI 内容创作，全部模型本地运行，完全离线",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron electron/main.cjs\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "download-models": "node scripts/download-models.cjs",
    "dist": "npm run electron:build:win"
  },
  "build": {
    "appId": "com.aitools.studio",
    "productName": "AI工具台",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*.cjs",
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png",
      "artifactName": "AI工具台-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI工具台",
      "installerLanguages": ["zh_CN", "zh_TW", "en_US"],
      "license": "LICENSE.txt",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/icon.png",
      "artifactName": "AI工具台-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icon.png",
      "artifactName": "AI工具台-${version}.${ext}"
    },
    "asarUnpack": [
      "node_modules/@mlc-ai/**/*",
      "models/**/*"
    ]
  },
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@mlc-ai/web-llm": "^0.2.84",
    "@types/three": "^0.185.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vercel": "^56.3.2",
    "wait-on": "^9.0.2"
  }
}
